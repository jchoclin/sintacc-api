{
  "name": "backend-typescript-bun",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "module": "server.ts",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "NODE_ENV=production bun run src/cluster.ts",
    "lint": "oxlint --type-aware --import-plugin .",
    "lint:fix": "oxlint --type-aware --import-plugin --fix .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.5.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  }
}
